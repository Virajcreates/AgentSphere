# Environment
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Application
APP_VERSION=0.1.0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentsphere
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/agentsphere
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API Keys
API_KEY_PREFIX=as_live

# Observability
OTEL_SERVICE_NAME=agentsphere-api
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Seed Data
SEED_ADMIN_EMAIL=admin@agentsphere.local
SEED_ADMIN_PASSWORD=